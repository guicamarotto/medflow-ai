{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@bull-board/api": "^6.6.2",
    "@bull-board/fastify": "^6.6.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@medflow/shared": "workspace:*",
    "@prisma/client": "^6.7.0",
    "@sentry/node": "^10.47.0",
    "bullmq": "^5.50.3",
    "fastify": "^5.3.2",
    "groq-sdk": "^0.22.0",
    "ioredis": "^5.6.0",
    "openai": "^6.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "eslint": "^9.39.4",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}