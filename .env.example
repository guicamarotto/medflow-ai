# ── Database ────────────────────────────────────────────────────
DATABASE_URL="postgresql://medflow:medflow@localhost:5432/medflow"

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── API ─────────────────────────────────────────────────────────
API_PORT=3001
WEB_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── NextAuth ─────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# ── AI Provider ──────────────────────────────────────────────────
# Switch AI_PROVIDER to change model — zero code changes needed

# Default: Groq (free tier, no credit card)
# Get your key at: https://console.groq.com
AI_PROVIDER=groq
GROQ_API_KEY=gsk_...

# Anthropic Claude (paid)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-4o (paid)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Ollama — 100% offline, no internet required
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ── Sentry (optional) ────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
